# Node
node_modules/ frontend/dist/
# IDE
.vscode/ .idea/ *.swp .DS_Store


# ═══════════════════════════════════════════════════════════════
#  Energy AI Platform — .gitignore
#  Covers: Python, Node.js, React, Vite, Docker, IDEs, OS files
# ═══════════════════════════════════════════════════════════════


# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env.local
.env.*.local
venv.bak/
env.bak/

# Environment variables (keep .env.example)
.env

# Database files
*.db
*.sqlite
*.sqlite3
energy_platform.db

