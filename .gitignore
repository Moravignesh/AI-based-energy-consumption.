# Build output
frontend/dist/
frontend/build/
frontend/.output/
frontend/.nuxt/
frontend/.next/
frontend/out/

# Cache
.npm
.eslintcache
.stylelintcache
frontend/.cache/
.parcel-cache/

# Yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Package lock (keep package-lock.json, ignore yarn.lock if using npm)
yarn.lock


# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock
lib-cov/


# ── Docker ───────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfiles
# Ignore override files with secrets
docker-compose.override.yml
docker-compose.prod.yml
.docker/


# ── Data files ───────────────────────────────────────────────
# Don't commit large datasets or uploaded files
backend/data/*.csv
backend/data/*.xlsx
backend/data/*.json
backend/data/*.parquet
!backend/data/.gitkeep

# ML model artifacts
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.pt
*.pth
models/
saved_models/


